import pyttsx3
import speech_recognition as sr
import openai
import re

client = openai.OpenAI(
    api_key= "d59b1e1e-2068-4698-a1c0-b1ec973df7ef",
    base_url="https://api.sambanova.ai/v1/chat/completions"
)

def botResponse (message) :
    completion = client.chat.completions.create(
    model="Llama-4-Maverick-17B-128E-Instruct",
    temperature=0.1,
    top_p=0.1,
    stream=True,
    max_tokens=700,
    messages=[
        {
			"role": "system",
			"content": ""
		},
		{
			"role": "user",
			"content": message
		}
       ]
    )
    full_response = ""
    for chunk in completion:
        if chunk.choices[0].delta.content is not None:
            full_response += chunk.choices[0].delta.content
    return completion.choices[0].message.content

def userSpeak () :
    recognizer =  sr.Recognizer()
    with sr.Microphone() as source :
        print("Speak....")
        recognizer.adjust_for_ambient_noise(source)
        audio = recognizer.listen(source)
        try :
            print("recognizing....")
            data = recognizer.recognize_google(audio)
            print(data)
            return data
        except sr.UnknownValueError :
            print("Please try to speak....")


def botSpeak (speech) :
    engine = pyttsx3.init()
    voices = engine.getProperty("voices")
    engine.setProperty("voice" , voices[0].id)
    rate = engine.getProperty("rate")
    engine.setProperty("rate" , 170)
    engine.say(speech)
    engine.runAndWait()


def main() :
    while True :
        command = userSpeak()
        print(command)
        if command.lower() == "exit" :
            print("Stopped")
            break
        raw_response = botResponse(command)
        cleaned_response = re.sub(r"<think>.*?</think>\s*", "", raw_response, flags=re.DOTALL)
        botSpeak(cleaned_response)



if __name__ == "__main__" :
    main()
